generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id                                             String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  full_name                                      String
  phone                                          String?                @unique
  email                                          String?                @unique
  password_hash                                  String
  is_active                                      Boolean                @default(true)
  created_at                                     DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  role                                           user_role
  ar_invoices_approved                           ar_invoices[]          @relation("ar_invoices_approved_by")
  ar_invoices_created                            ar_invoices[]          @relation("ar_invoices_created_by")
  ar_payments_approved                           ar_payments[]          @relation("ar_payments_approved_by")
  ar_payments_created                            ar_payments[]          @relation("ar_payments_created_by")
  cash_advances_supervisor                       cash_advances[]        @relation("cash_advances_supervisor")
  cash_advances_issued                           cash_advances[]        @relation("cash_advances_issued_by")
  cash_expense_audits                            cash_expense_audits[]
  cash_expenses_cash_expenses_appealed_byTousers cash_expenses[]        @relation("cash_expenses_appealed_byTousers")
  cash_expenses_approved                         cash_expenses[]        @relation("cash_expenses_approved_by")
  cash_expenses_created                          cash_expenses[]        @relation("cash_expenses_created_by")
  cash_expenses_rejected                         cash_expenses[]        @relation("cash_expenses_rejected_by")
  cash_expenses_resolved                         cash_expenses[]        @relation("cash_expenses_resolved_by")
  inventory_issues_issued                        inventory_issues[]     @relation("inventory_issues_issued_by")
  inventory_receipts_created_by                  inventory_receipts[]   @relation("inventory_receipts_created_by")
  inventory_receipts_submitted_by                inventory_receipts[]   @relation("inventory_receipts_submitted_by")
  inventory_requests_created                     inventory_requests[]   @relation("inventory_requests_created_by")
  maintenance_requests_created                   maintenance_requests[] @relation("maintenance_requests_requested_by")
  maintenance_requests_reviewed                  maintenance_requests[] @relation("maintenance_requests_reviewed_by")
  trip_assignments_supervisor                    trip_assignments[]     @relation("trip_assignments_supervisor")
  trip_events_created                            trip_events[]          @relation("trip_events_created_by")
  trip_revenues_approved                         trip_revenues[]        @relation("trip_revenues_approved_by")
  trip_revenues_entered                          trip_revenues[]        @relation("trip_revenues_entered_by")
  trips_created                                  trips[]                @relation("trips_created_by")
  trips_trips_financial_closed_byTousers         trips[]                @relation("trips_financial_closed_byTousers")
  trips_trips_general_supervisor_idTousers       trips[]                @relation("trips_general_supervisor_idTousers")
  vehicle_portfolio                              vehicle_portfolio[]
  supervised_vehicles                            vehicles[]             @relation("vehicles_supervisor")
  vendor_transactions_created                    vendor_transactions[]

  @@map("users")
}

model vendors {
  id                      String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                    String
  code                    String?                   @unique
  vendor_type             vendor_type
  classification          vendor_classification     @default(EXTERNAL)
  status                  vendor_status             @default(ACTIVE)
  specialization          String?
  contact_person          String?
  phone                   String?
  phone2                  String?
  email                   String?
  address                 String?
  city                    String?
  tax_no                  String?
  commercial_register     String?
  payment_terms           String?
  opening_balance         Decimal?                  @db.Decimal(12, 2)
  credit_limit            Decimal?                  @db.Decimal(12, 2)
  notes                   String?
  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  cash_expenses           cash_expenses[]
  inventory_receipts      inventory_receipts[]
  maintenance_work_orders maintenance_work_orders[]
  vendor_transactions     vendor_transactions[]

  @@index([name], map: "idx_vendors_name")
  @@index([vendor_type], map: "idx_vendors_vendor_type")
  @@index([status], map: "idx_vendors_status")
  @@map("vendors")
}

model vendor_transactions {
  id                           String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vendor_id                    String                    @db.Uuid
  transaction_type             vendor_transaction_type
  amount                       Decimal                   @db.Decimal(12, 2)
  transaction_date             DateTime                  @default(now()) @db.Timestamptz(6)
  reference_no                 String?
  notes                        String?
  related_cash_expense_id      String?                   @db.Uuid
  related_work_order_id        String?                   @db.Uuid
  related_inventory_receipt_id String?                   @db.Uuid
  created_by                   String?                   @db.Uuid
  created_at                   DateTime                  @default(now()) @db.Timestamptz(6)
  status                       vendor_transaction_status @default(APPROVED)
  users                        users?                    @relation(fields: [created_by], references: [id])
  cash_expense                 cash_expenses?            @relation(fields: [related_cash_expense_id], references: [id])
  inventory_receipt            inventory_receipts?       @relation(fields: [related_inventory_receipt_id], references: [id])
  work_order                   maintenance_work_orders?  @relation(fields: [related_work_order_id], references: [id])
  vendors                      vendors                   @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@index([vendor_id], map: "idx_vendor_transactions_vendor_id")
  @@index([transaction_date], map: "idx_vendor_transactions_date")
  @@map("vendor_transactions")
}

model vehicles {
  id                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @updatedAt @db.Timestamptz(6)
  model                    String?
  year                     Int?
  current_odometer         Int?
  display_name             String?
  fleet_no                 String                     @unique
  gps_device_id            String?
  is_active                Boolean                    @default(true)
  plate_no                 String                     @unique
  supervisor_id            String?                    @db.Uuid
  disable_reason           vehicle_disable_reason?
  license_expiry_date      DateTime?                  @db.Timestamptz(6)
  license_issue_date       DateTime?                  @db.Timestamptz(6)
  license_no               String?
  status                   vehicle_status             @default(AVAILABLE)
  cash_expenses            cash_expenses[]
  maintenance_requests     maintenance_requests[]
  maintenance_work_orders  maintenance_work_orders[]
  installed_part_items     part_items[]               @relation("part_items_installed_vehicle")
  trip_assignments         trip_assignments[]
  vehicle_portfolio        vehicle_portfolio[]
  supervisor               users?                     @relation("vehicles_supervisor", fields: [supervisor_id], references: [id], onUpdate: NoAction)
  work_order_installations work_order_installations[]

  @@index([supervisor_id], map: "idx_vehicles_supervisor_id")
  @@index([license_expiry_date], map: "idx_vehicles_license_expiry")
  @@index([status], map: "idx_vehicles_status")
  @@map("vehicles")
}

model clients {
  id            String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name          String
  is_active     Boolean            @default(true)
  created_at    DateTime           @default(now()) @db.Timestamptz(6)
  updated_at    DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  contact_email String?
  contact_name  String?
  contact_phone String?
  email         String?
  hq_address    String?
  notes         String?
  phone         String?
  tax_no        String?
  ar_invoices   ar_invoices[]
  ar_payments   ar_payments[]
  contracts     client_contracts[]
  sites         sites[]
  trip_revenues trip_revenues[]
  trips         trips[]

  @@index([name], map: "idx_clients_name")
  @@map("clients")
}

model client_contracts {
  id             String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id      String                 @db.Uuid
  contract_no    String?                @unique
  start_date     DateTime               @db.Timestamptz(6)
  end_date       DateTime?              @db.Timestamptz(6)
  billing_cycle  contract_billing_cycle @default(MONTHLY)
  contract_value Decimal?               @db.Decimal(12, 2)
  currency       String?                @default("EGP")
  status         contract_status        @default(ACTIVE)
  notes          String?
  created_at     DateTime               @default(now()) @db.Timestamptz(6)
  updated_at     DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  ar_invoices    ar_invoices[]
  clients        clients                @relation(fields: [client_id], references: [id], onDelete: Cascade)
  trip_revenues  trip_revenues[]
  trips          trips[]

  @@index([client_id], map: "idx_client_contracts_client_id")
  @@index([status], map: "idx_client_contracts_status")
  @@map("client_contracts")
}

model ar_invoices {
  id                 String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id          String                   @db.Uuid
  contract_id        String?                  @db.Uuid
  invoice_no         String                   @unique
  issue_date         DateTime                 @default(now()) @db.Timestamptz(6)
  due_date           DateTime?                @db.Timestamptz(6)
  amount             Decimal                  @db.Decimal(12, 2)
  vat_amount         Decimal?                 @db.Decimal(12, 2)
  total_amount       Decimal                  @db.Decimal(12, 2)
  status             ar_invoice_status        @default(DRAFT)
  created_by         String?                  @db.Uuid
  created_at         DateTime                 @default(now()) @db.Timestamptz(6)
  approved_by        String?                  @db.Uuid
  approved_at        DateTime?                @db.Timestamptz(6)
  rejection_reason   String?
  notes              String?
  invoice_trip_lines ar_invoice_trip_lines[]
  users_approved     users?                   @relation("ar_invoices_approved_by", fields: [approved_by], references: [id])
  clients            clients                  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  client_contracts   client_contracts?        @relation(fields: [contract_id], references: [id])
  users_created      users?                   @relation("ar_invoices_created_by", fields: [created_by], references: [id])
  payments           ar_payment_allocations[]
  trip_revenues      trip_revenues[]

  @@index([client_id], map: "idx_ar_invoices_client_id")
  @@index([status], map: "idx_ar_invoices_status")
  @@index([issue_date], map: "idx_ar_invoices_issue_date")
  @@index([due_date], map: "idx_ar_invoices_due_date")
  @@map("ar_invoices")
}

model ar_payments {
  id               String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id        String                   @db.Uuid
  payment_date     DateTime                 @default(now()) @db.Timestamptz(6)
  amount           Decimal                  @db.Decimal(12, 2)
  method           ar_payment_method        @default(BANK_TRANSFER)
  reference        String?
  notes            String?
  status           ar_payment_status        @default(DRAFT)
  created_by       String?                  @db.Uuid
  created_at       DateTime                 @default(now()) @db.Timestamptz(6)
  approved_by      String?                  @db.Uuid
  approved_at      DateTime?                @db.Timestamptz(6)
  rejection_reason String?
  allocations      ar_payment_allocations[]
  users_approved   users?                   @relation("ar_payments_approved_by", fields: [approved_by], references: [id])
  clients          clients                  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  users_created    users?                   @relation("ar_payments_created_by", fields: [created_by], references: [id])

  @@index([client_id], map: "idx_ar_payments_client_id")
  @@index([status], map: "idx_ar_payments_status")
  @@index([payment_date], map: "idx_ar_payments_payment_date")
  @@map("ar_payments")
}

model ar_payment_allocations {
  id               String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  payment_id       String      @db.Uuid
  invoice_id       String      @db.Uuid
  amount_allocated Decimal     @db.Decimal(12, 2)
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  ar_invoices      ar_invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  ar_payments      ar_payments @relation(fields: [payment_id], references: [id], onDelete: Cascade)

  @@unique([payment_id, invoice_id], map: "uq_ar_alloc_payment_invoice")
  @@index([payment_id], map: "idx_ar_alloc_payment_id")
  @@index([invoice_id], map: "idx_ar_alloc_invoice_id")
  @@map("ar_payment_allocations")
}

model ar_invoice_trip_lines {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  invoice_id  String      @db.Uuid
  trip_id     String      @db.Uuid
  amount      Decimal     @db.Decimal(12, 2)
  notes       String?
  ar_invoices ar_invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  trips       trips       @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@unique([invoice_id, trip_id], map: "uq_ar_invoice_trip")
  @@index([invoice_id], map: "idx_ar_invoice_trip_invoice_id")
  @@index([trip_id], map: "idx_ar_invoice_trip_trip_id")
  @@map("ar_invoice_trip_lines")
}

model sites {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id  String   @db.Uuid
  name       String
  address    String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  clients    clients  @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  site_trips trips[]  @relation("trips_site")

  @@index([client_id], map: "idx_sites_client_id")
  @@map("sites")
}

model trips {
  id                                       String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id                                String                  @db.Uuid
  site_id                                  String                  @db.Uuid
  created_by                               String                  @db.Uuid
  general_supervisor_id                    String?                 @db.Uuid
  scheduled_at                             DateTime?               @db.Timestamptz(6)
  trip_type                                String?
  notes                                    String?
  created_at                               DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  financial_closed_at                      DateTime?               @db.Timestamptz(6)
  financial_closed_by                      String?                 @db.Uuid
  financial_review_opened_at               DateTime?               @db.Timestamptz(6)
  trip_code                                String                  @unique
  actual_arrival_at                        DateTime?               @db.Timestamptz(6)
  actual_departure_at                      DateTime?               @db.Timestamptz(6)
  agreed_revenue                           Decimal?                @db.Decimal(12, 2)
  cargo_type                               String?
  cargo_weight                             Decimal?                @db.Decimal(12, 3)
  destination                              String?
  origin                                   String?
  revenue_currency                         String?                 @default("EGP")
  revenue_entry_mode                       revenue_entry_mode?
  status                                   trip_status             @default(DRAFT)
  financial_status                         trip_financial_status   @default(OPEN)
  contract_id                              String?                 @db.Uuid
  invoice_trip_lines                       ar_invoice_trip_lines[]
  cash_expenses                            cash_expenses[]
  trip_assignments                         trip_assignments[]
  trip_events                              trip_events[]
  trip_revenues                            trip_revenues[]
  clients                                  clients                 @relation(fields: [client_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  client_contracts                         client_contracts?       @relation(fields: [contract_id], references: [id])
  users_trips_created_byTousers            users                   @relation("trips_created_by", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_trips_financial_closed_byTousers   users?                  @relation("trips_financial_closed_byTousers", fields: [financial_closed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_trips_general_supervisor_idTousers users?                  @relation("trips_general_supervisor_idTousers", fields: [general_supervisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  site                                     sites                   @relation("trips_site", fields: [site_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at], map: "idx_trips_created_at")
  @@index([status], map: "idx_trips_status")
  @@index([financial_status], map: "idx_trips_financial_status")
  @@index([client_id], map: "idx_trips_client_id")
  @@index([contract_id], map: "idx_trips_contract_id")
  @@index([site_id], map: "idx_trips_site_id")
  @@index([created_at])
  @@map("trips")
}

model trip_revenues {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trip_id          String              @db.Uuid
  client_id        String              @db.Uuid
  contract_id      String?             @db.Uuid
  invoice_id       String?             @db.Uuid
  amount           Decimal             @db.Decimal(12, 2)
  currency         String?             @default("EGP")
  source           trip_revenue_source @default(MANUAL)
  entered_by       String?             @db.Uuid
  approved_by      String?             @db.Uuid
  entered_at       DateTime            @default(now()) @db.Timestamptz(6)
  approved_at      DateTime?           @db.Timestamptz(6)
  notes            String?
  users_approved   users?              @relation("trip_revenues_approved_by", fields: [approved_by], references: [id])
  clients          clients             @relation(fields: [client_id], references: [id], onDelete: Cascade)
  client_contracts client_contracts?   @relation(fields: [contract_id], references: [id])
  users_entered    users?              @relation("trip_revenues_entered_by", fields: [entered_by], references: [id])
  ar_invoices      ar_invoices?        @relation(fields: [invoice_id], references: [id])
  trips            trips               @relation(fields: [trip_id], references: [id], onDelete: Cascade)

  @@index([trip_id], map: "idx_trip_revenues_trip_id")
  @@index([client_id], map: "idx_trip_revenues_client_id")
  @@index([invoice_id], map: "idx_trip_revenues_invoice_id")
  @@map("trip_revenues")
}

model trip_assignments {
  id                                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trip_id                           String    @db.Uuid
  vehicle_id                        String    @db.Uuid
  driver_id                         String    @db.Uuid
  field_supervisor_id               String?   @db.Uuid
  assigned_at                       DateTime  @default(now()) @db.Timestamptz(6)
  is_active                         Boolean   @default(true)
  unassigned_at                     DateTime? @db.Timestamptz(6)
  drivers                           drivers   @relation(fields: [driver_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_trip_assignments_supervisor users?    @relation("trip_assignments_supervisor", fields: [field_supervisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips                             trips     @relation(fields: [trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles                          vehicles  @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([trip_id], map: "idx_trip_assignments_trip_id")
  @@index([vehicle_id], map: "idx_trip_assignments_vehicle_id")
  @@index([driver_id], map: "idx_trip_assignments_driver_id")
  @@map("trip_assignments")
}

model trip_events {
  id                                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  trip_id                             String   @db.Uuid
  event_type                          String
  created_by_user                     String?  @db.Uuid
  payload                             Json?
  created_at                          DateTime @default(now()) @db.Timestamptz(6)
  users_trip_events_created_byTousers users?   @relation("trip_events_created_by", fields: [created_by_user], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips                               trips    @relation(fields: [trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([trip_id], map: "idx_trip_events_trip_id")
  @@index([event_type], map: "idx_trip_events_event_type")
  @@map("trip_events")
}

model vehicle_portfolio {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  vehicle_id          String   @db.Uuid
  field_supervisor_id String   @db.Uuid
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  users               users    @relation(fields: [field_supervisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles            vehicles @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([vehicle_id, field_supervisor_id], map: "uq_vehicle_portfolio_vehicle_supervisor")
  @@map("vehicle_portfolio")
}

model cash_advances {
  id                                             String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  field_supervisor_id                            String              @db.Uuid
  issued_by                                      String              @db.Uuid
  amount                                         Decimal             @db.Decimal(12, 2)
  created_at                                     DateTime            @default(now()) @db.Timestamptz(6)
  updated_at                                     DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  settled_at                                     DateTime?           @db.Timestamptz(6)
  settled_by                                     String?             @db.Uuid
  settlement_amount                              Decimal?            @db.Decimal(12, 2)
  settlement_notes                               String?
  settlement_reference                           String?
  settlement_type                                String?
  status                                         cash_advance_status @default(OPEN)
  users_cash_advances_field_supervisor_idTousers users               @relation("cash_advances_supervisor", fields: [field_supervisor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_cash_advances_issued_byTousers           users               @relation("cash_advances_issued_by", fields: [issued_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cash_expenses                                  cash_expenses[]

  @@index([field_supervisor_id], map: "idx_cash_advances_supervisor_id")
  @@index([status], map: "idx_cash_advances_status")
  @@map("cash_advances")
}

model cash_expenses {
  id                                     String                       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  cash_advance_id                        String?                      @db.Uuid
  trip_id                                String?                      @db.Uuid
  vehicle_id                             String?                      @db.Uuid
  expense_type                           cash_expense_type
  amount                                 Decimal                      @db.Decimal(12, 2)
  notes                                  String?
  receipt_url                            String?
  created_by                             String                       @db.Uuid
  created_at                             DateTime                     @default(now()) @db.Timestamptz(6)
  approved_at                            DateTime?                    @db.Timestamptz(6)
  approved_by                            String?                      @db.Uuid
  rejection_reason                       String?
  rejected_by                            String?                      @db.Uuid
  rejected_at                            DateTime?                    @db.Timestamptz(6)
  appealed_by                            String?                      @db.Uuid
  appealed_at                            DateTime?                    @db.Timestamptz(6)
  resolved_by                            String?                      @db.Uuid
  resolved_at                            DateTime?                    @db.Timestamptz(6)
  appeal_reason                          String?
  appeal_status                          String?
  resolution_notes                       String?
  updated_at                             DateTime                     @default(now()) @updatedAt @db.Timestamptz(6)
  maintenance_work_order_id              String?                      @db.Uuid
  invoice_date                           DateTime?                    @db.Timestamptz(6)
  invoice_no                             String?
  invoice_total                          Decimal?                     @db.Decimal(12, 2)
  paid_method                            String?
  payment_ref                            String?
  payment_source                         cash_payment_source          @default(ADVANCE)
  vat_amount                             Decimal?                     @db.Decimal(12, 2)
  inventory_receipt_id                   String?                      @db.Uuid
  vendor_id                              String?                      @db.Uuid
  approval_status                        cash_expense_approval_status @default(PENDING)
