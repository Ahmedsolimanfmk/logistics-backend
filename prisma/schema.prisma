model ai_conversations {
  id              String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id      String                 @db.Uuid
  user_id         String                 @db.Uuid
  title           String?
  context         String?
  status          ai_conversation_status @default(ACTIVE)
  last_message_at DateTime?              @db.Timestamptz(6)
  created_at      DateTime               @default(now()) @db.Timestamptz(6)
  updated_at      DateTime               @default(now()) @updatedAt @db.Timestamptz(6)

  company     companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  user        users            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages    ai_messages[]
  query_runs  ai_query_runs[]
  action_runs ai_action_runs[]

  @@index([company_id], map: "idx_ai_conversations_company_id")
  @@index([user_id], map: "idx_ai_conversations_user_id")
  @@index([status], map: "idx_ai_conversations_status")
  @@index([last_message_at], map: "idx_ai_conversations_last_message_at")
  @@map("ai_conversations")
}

model ai_messages {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id      String          @db.Uuid
  conversation_id String          @db.Uuid
  user_id         String?         @db.Uuid
  role            ai_message_role
  content         String
  parsed_mode     String?
  parsed_intent   String?
  parsed_json     Json?
  response_json   Json?
  created_at      DateTime        @default(now()) @db.Timestamptz(6)

  company      companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  conversation ai_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user         users?           @relation(fields: [user_id], references: [id])

  query_runs  ai_query_runs[]
  action_runs ai_action_runs[]

  @@index([company_id], map: "idx_ai_messages_company_id")
  @@index([conversation_id], map: "idx_ai_messages_conversation_id")
  @@index([user_id], map: "idx_ai_messages_user_id")
  @@index([role], map: "idx_ai_messages_role")
  @@index([created_at], map: "idx_ai_messages_created_at")
  @@map("ai_messages")
}

model ai_query_runs {
  id               String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String        @db.Uuid
  conversation_id  String?       @db.Uuid
  message_id       String?       @db.Uuid
  user_id          String?       @db.Uuid
  question         String
  parsed_json      Json?
  analytics_query  Json?
  result_json      Json?
  session_snapshot Json?
  status           ai_run_status @default(PENDING)
  error_message    String?
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  finished_at      DateTime?     @db.Timestamptz(6)

  company      companies         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  conversation ai_conversations? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  message      ai_messages?      @relation(fields: [message_id], references: [id], onDelete: SetNull)
  user         users?            @relation(fields: [user_id], references: [id])

  @@index([company_id], map: "idx_ai_query_runs_company_id")
  @@index([conversation_id], map: "idx_ai_query_runs_conversation_id")
  @@index([message_id], map: "idx_ai_query_runs_message_id")
  @@index([user_id], map: "idx_ai_query_runs_user_id")
  @@index([status], map: "idx_ai_query_runs_status")
  @@index([created_at], map: "idx_ai_query_runs_created_at")
  @@map("ai_query_runs")
}

model ai_action_runs {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id      String        @db.Uuid
  conversation_id String?       @db.Uuid
  message_id      String?       @db.Uuid
  user_id         String?       @db.Uuid
  action_name     String
  payload_json    Json?
  result_json     Json?
  status          ai_run_status @default(PENDING)
  error_message   String?
  executed_at     DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)

  company      companies         @relation(fields: [company_id], references: [id], onDelete: Cascade)
  conversation ai_conversations? @relation(fields: [conversation_id], references: [id], onDelete: SetNull)
  message      ai_messages?      @relation(fields: [message_id], references: [id], onDelete: SetNull)
  user         users?            @relation(fields: [user_id], references: [id])

  @@index([company_id], map: "idx_ai_action_runs_company_id")
  @@index([conversation_id], map: "idx_ai_action_runs_conversation_id")
  @@index([message_id], map: "idx_ai_action_runs_message_id")
  @@index([user_id], map: "idx_ai_action_runs_user_id")
  @@index([status], map: "idx_ai_action_runs_status")
  @@index([created_at], map: "idx_ai_action_runs_created_at")
  @@map("ai_action_runs")
}

model vehicle_classes {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String   @db.Uuid
  code        String
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  company                companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contract_pricing_rules contract_pricing_rules[]

  @@unique([company_id, code])
  @@index([company_id])
  @@map("vehicle_classes")
}

model cargo_types {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String   @db.Uuid
  code        String
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  company                companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  contract_pricing_rules contract_pricing_rules[]

  @@unique([company_id, code])
  @@index([company_id])
  @@map("cargo_types")
