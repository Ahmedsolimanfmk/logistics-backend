model zones {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String   @db.Uuid
  code       String
  name       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())

  company            companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  pricing_rules_from contract_pricing_rules[] @relation("pricing_from_zone")
  pricing_rules_to   contract_pricing_rules[] @relation("pricing_to_zone")
  sites              sites[]

  @@unique([company_id, code])
  @@index([company_id])
}

model contract_pricing_rules {
  id          String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String @db.Uuid
  contract_id String @db.Uuid
  client_id   String @db.Uuid

  route_id         String? @db.Uuid
  pickup_site_id   String? @db.Uuid
  dropoff_site_id  String? @db.Uuid
  from_zone_id     String? @db.Uuid
  to_zone_id       String? @db.Uuid
  vehicle_class_id String? @db.Uuid
  cargo_type_id    String? @db.Uuid

  trip_type String?

  min_weight Decimal? @db.Decimal(12, 2)
  max_weight Decimal? @db.Decimal(12, 2)

  base_price    Decimal  @db.Decimal(12, 2)
  currency      String?  @default("EGP")
  price_per_ton Decimal? @db.Decimal(12, 2)
  price_per_km  Decimal? @db.Decimal(12, 2)

  priority Int? @default(100)

  effective_from DateTime? @db.Timestamptz(6)
  effective_to   DateTime? @db.Timestamptz(6)

  is_active Boolean @default(true)
  notes     String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  companies        companies        @relation(fields: [company_id], references: [id], onDelete: Cascade)
  clients          clients          @relation(fields: [client_id], references: [id], onDelete: Cascade)
  client_contracts client_contracts @relation(fields: [contract_id], references: [id], onDelete: Cascade)
  routes           routes?          @relation(fields: [route_id], references: [id], onDelete: SetNull)
  pickup_site      sites?           @relation("pricing_pickup_site", fields: [pickup_site_id], references: [id], onDelete: SetNull)
  dropoff_site     sites?           @relation("pricing_dropoff_site", fields: [dropoff_site_id], references: [id], onDelete: SetNull)
  from_zone        zones?           @relation("pricing_from_zone", fields: [from_zone_id], references: [id], onDelete: SetNull)
  to_zone          zones?           @relation("pricing_to_zone", fields: [to_zone_id], references: [id], onDelete: SetNull)
  vehicle_classes  vehicle_classes? @relation(fields: [vehicle_class_id], references: [id], onDelete: SetNull)
  cargo_types      cargo_types?     @relation(fields: [cargo_type_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([client_id])
  @@index([contract_id])
  @@index([route_id])
  @@index([vehicle_class_id])
  @@index([cargo_type_id])
  @@index([pickup_site_id])
  @@index([dropoff_site_id])
  @@index([from_zone_id])
  @@index([to_zone_id])
  @@map("contract_pricing_rules")
}

model routes {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String  @db.Uuid
  client_id  String? @db.Uuid

  code String?
  name String

  pickup_site_id  String? @db.Uuid
  dropoff_site_id String? @db.Uuid

  origin_label      String?
  destination_label String?
  distance_km       Decimal? @db.Decimal(12, 2)

  is_active Boolean @default(true)
  notes     String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  companies    companies @relation(fields: [company_id], references: [id], onDelete: Cascade)
  clients      clients?  @relation(fields: [client_id], references: [id], onDelete: SetNull)
  pickup_site  sites?    @relation("route_pickup_site", fields: [pickup_site_id], references: [id], onDelete: SetNull)
  dropoff_site sites?    @relation("route_dropoff_site", fields: [dropoff_site_id], references: [id], onDelete: SetNull)

  contract_pricing_rules contract_pricing_rules[]

  @@index([company_id])
  @@index([client_id])
  @@index([pickup_site_id])
  @@index([dropoff_site_id])
  @@map("routes")
}
