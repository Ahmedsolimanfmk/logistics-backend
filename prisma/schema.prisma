generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model users {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  employee_code String?   @unique
  full_name     String
  phone         String?   @unique
  email         String?   @unique
  password_hash String
  is_active     Boolean   @default(true)
  last_login_at DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  role          user_role
  platform_role platform_role @default(USER)

  memberships company_users[]

  ar_invoices_approved_by              ar_invoices[]                   @relation("ar_invoices_approved_by")
  ar_invoices_created_by               ar_invoices[]                   @relation("ar_invoices_created_by")
  ar_payments_approved_by              ar_payments[]                   @relation("ar_payments_approved_by")
  ar_payments_created_by               ar_payments[]                   @relation("ar_payments_created_by")
  ar_payments_submitted_by             ar_payments[]                   @relation("ar_payments_submitted_by")
  ar_payments_posted_by                ar_payments[]                   @relation("ar_payments_posted_by")
  cash_advances_supervisor             cash_advances[]                 @relation("cash_advances_supervisor")
  cash_advances_issued_by              cash_advances[]                 @relation("cash_advances_issued_by")
  cash_expense_audits                  cash_expense_audits[]
  cash_expenses_created_by             cash_expenses[]                 @relation("cash_expenses_created_by")
  cash_expenses_approved_by            cash_expenses[]                 @relation("cash_expenses_approved_by")
  cash_expenses_rejected_by            cash_expenses[]                 @relation("cash_expenses_rejected_by")
  cash_expenses_appealed_by            cash_expenses[]                 @relation("cash_expenses_appealed_by")
  cash_expenses_resolved_by            cash_expenses[]                 @relation("cash_expenses_resolved_by")
  inventory_issues_issued_by           inventory_issues[]              @relation("inventory_issues_issued_by")
  inventory_issues_approved_by         inventory_issues[]              @relation("inventory_issues_approved_by")
  inventory_receipts_created_by        inventory_receipts[]            @relation("inventory_receipts_created_by")
  inventory_receipts_submitted_by      inventory_receipts[]            @relation("inventory_receipts_submitted_by")
  inventory_receipts_approved_by       inventory_receipts[]            @relation("inventory_receipts_approved_by")
  inventory_requests_created_by        inventory_requests[]            @relation("inventory_requests_created_by")
  inventory_requests_approved_by       inventory_requests[]            @relation("inventory_requests_approved_by")
  inventory_requests_rejected_by       inventory_requests[]            @relation("inventory_requests_rejected_by")
  maintenance_requests_requested_by    maintenance_requests[]          @relation("maintenance_requests_requested_by")
  maintenance_requests_reviewed_by     maintenance_requests[]          @relation("maintenance_requests_reviewed_by")
  maintenance_work_orders_created_by   maintenance_work_orders[]       @relation("maintenance_work_orders_created_by")
  maintenance_work_orders_approved_by  maintenance_work_orders[]       @relation("maintenance_work_orders_approved_by")
  maintenance_work_orders_cancelled_by maintenance_work_orders[]       @relation("maintenance_work_orders_cancelled_by")
  maintenance_work_order_events_actor  maintenance_work_order_events[] @relation("maintenance_work_order_events_actor")
  post_maintenance_reports_checked_by  post_maintenance_reports[]      @relation("post_maintenance_reports_checked_by")
  post_maintenance_reports_approved_by post_maintenance_reports[]      @relation("post_maintenance_reports_approved_by")
  supervisor_assignments               supervisor_assignments[]
  trip_assignments_supervisor          trip_assignments[]              @relation("trip_assignments_supervisor")
  trip_events_actor                    trip_events[]                   @relation("trip_events_actor")
  trip_revenues_entered_by             trip_revenues[]                 @relation("trip_revenues_entered_by")
  trip_revenues_approved_by            trip_revenues[]                 @relation("trip_revenues_approved_by")
  trips_created_by                     trips[]                         @relation("trips_created_by")
  trips_general_supervisor             trips[]                         @relation("trips_general_supervisor")
  trips_financial_closed_by            trips[]                         @relation("trips_financial_closed_by")
  trips_cancelled_by                   trips[]                         @relation("trips_cancelled_by")
  vendor_transactions_created_by       vendor_transactions[]
  warehouses_managed                   warehouses[]                    @relation("warehouses_manager")
  alert_reads                          alert_reads[]
  ai_conversations                     ai_conversations[]
  ai_messages                          ai_messages[]
  ai_query_runs                        ai_query_runs[]
  ai_action_runs                       ai_action_runs[]

  @@map("users")
}

model departments {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id  String   @db.Uuid
  code        String
  name        String
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  company                companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  fleets                 fleets[]
  supervisor_assignments supervisor_assignments[]

  @@unique([company_id, code], map: "uq_departments_company_code")
  @@index([company_id], map: "idx_departments_company_id")
  @@index([is_active], map: "idx_departments_is_active")
  @@map("departments")
}

model fleets {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String   @db.Uuid
  department_id String   @db.Uuid
  code          String
  name          String
  description   String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  company                companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  department             departments              @relation(fields: [department_id], references: [id], onDelete: Cascade)
  fleet_vehicles         fleet_vehicles[]
  fleet_site_assignments fleet_site_assignments[]
  supervisor_assignments supervisor_assignments[]

  @@unique([company_id, code], map: "uq_fleets_company_code")
  @@index([company_id], map: "idx_fleets_company_id")
  @@index([department_id], map: "idx_fleets_department_id")
  @@index([is_active], map: "idx_fleets_is_active")
  @@map("fleets")
}

model fleet_vehicles {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String    @db.Uuid
  fleet_id      String    @db.Uuid
  vehicle_id    String    @db.Uuid
  assigned_at   DateTime  @default(now()) @db.Timestamptz(6)
  unassigned_at DateTime? @db.Timestamptz(6)
  ended_reason  String?
  is_active     Boolean   @default(true)
  notes         String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  company         companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  fleet           fleets         @relation(fields: [fleet_id], references: [id], onDelete: Cascade)
  vehicle         vehicles       @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
  companyUsers    company_users? @relation(fields: [company_usersId], references: [id])
  company_usersId String?        @db.Uuid

  @@index([company_id], map: "idx_fleet_vehicles_company_id")
  @@index([fleet_id], map: "idx_fleet_vehicles_fleet_id")
  @@index([vehicle_id], map: "idx_fleet_vehicles_vehicle_id")
  @@index([is_active], map: "idx_fleet_vehicles_is_active")
  @@map("fleet_vehicles")
}

model fleet_site_assignments {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String    @db.Uuid
  fleet_id      String    @db.Uuid
  site_id       String    @db.Uuid
  assigned_at   DateTime  @default(now()) @db.Timestamptz(6)
  unassigned_at DateTime? @db.Timestamptz(6)
  ended_reason  String?
  is_active     Boolean   @default(true)
  notes         String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  company         companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  fleet           fleets         @relation(fields: [fleet_id], references: [id], onDelete: Cascade)
  site            sites          @relation(fields: [site_id], references: [id], onDelete: Cascade)
  companyUsers    company_users? @relation(fields: [company_usersId], references: [id])
  company_usersId String?        @db.Uuid

  @@index([company_id], map: "idx_fleet_site_assignments_company_id")
  @@index([fleet_id], map: "idx_fleet_site_assignments_fleet_id")
  @@index([site_id], map: "idx_fleet_site_assignments_site_id")
  @@index([is_active], map: "idx_fleet_site_assignments_is_active")
  @@map("fleet_site_assignments")
}

model supervisor_assignments {
  id            String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id    String           @db.Uuid
  supervisor_id String           @db.Uuid
  department_id String?          @db.Uuid
  fleet_id      String?          @db.Uuid
  site_id       String?          @db.Uuid
  role_scope    supervisor_scope
  assigned_at   DateTime         @default(now()) @db.Timestamptz(6)
  unassigned_at DateTime?        @db.Timestamptz(6)
  ended_reason  String?
  is_active     Boolean          @default(true)
  notes         String?
  created_at    DateTime         @default(now()) @db.Timestamptz(6)
  updated_at    DateTime         @default(now()) @updatedAt @db.Timestamptz(6)

  company         companies      @relation(fields: [company_id], references: [id], onDelete: Cascade)
  supervisor      users          @relation(fields: [supervisor_id], references: [id], onDelete: Cascade)
  department      departments?   @relation(fields: [department_id], references: [id], onDelete: Cascade)
  fleet           fleets?        @relation(fields: [fleet_id], references: [id], onDelete: Cascade)
  site            sites?         @relation(fields: [site_id], references: [id], onDelete: Cascade)
  companyUsers    company_users? @relation(fields: [company_usersId], references: [id])
  company_usersId String?        @db.Uuid

  @@index([company_id], map: "idx_supervisor_assignments_company_id")
  @@index([supervisor_id], map: "idx_supervisor_assignments_supervisor_id")
  @@index([department_id], map: "idx_supervisor_assignments_department_id")
  @@index([fleet_id], map: "idx_supervisor_assignments_fleet_id")
  @@index([site_id], map: "idx_supervisor_assignments_site_id")
  @@index([is_active], map: "idx_supervisor_assignments_is_active")
  @@map("supervisor_assignments")
}

model vendors {
  id                   String                @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id           String                @db.Uuid
  name                 String
  code                 String?
  vendor_type          vendor_type
  classification       vendor_classification @default(EXTERNAL)
  status               vendor_status         @default(ACTIVE)
  specialization       String?
  contact_person       String?
  phone                String?
  phone2               String?
  email                String?
  address              String?
  city                 String?
  tax_no               String?
  commercial_register  String?
  payment_terms        String?
  currency             String?               @default("EGP")
  opening_balance      Decimal?              @db.Decimal(12, 2)
  opening_balance_date DateTime?             @db.Timestamptz(6)
  credit_limit         Decimal?              @db.Decimal(12, 2)
  is_blacklisted       Boolean               @default(false)
  notes                String?
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  updated_at           DateTime              @default(now()) @updatedAt @db.Timestamptz(6)

  company                 companies                 @relation(fields: [company_id], references: [id], onDelete: Cascade)
  cash_expenses           cash_expenses[]
  inventory_receipts      inventory_receipts[]
  maintenance_work_orders maintenance_work_orders[]
  vendor_transactions     vendor_transactions[]

  @@unique([company_id, code], map: "uq_vendors_company_code")
  @@index([company_id], map: "idx_vendors_company_id")
  @@index([name], map: "idx_vendors_name")
  @@index([vendor_type], map: "idx_vendors_vendor_type")
  @@index([status], map: "idx_vendors_status")
  @@map("vendors")
}

model vendor_transactions {
  id                           String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id                   String                    @db.Uuid
  vendor_id                    String                    @db.Uuid
  transaction_type             vendor_transaction_type
  reference_type               vendor_reference_type     @default(MANUAL)
  amount                       Decimal                   @db.Decimal(12, 2)
  currency                     String?                   @default("EGP")
  exchange_rate                Decimal?                  @db.Decimal(12, 6)
  transaction_date             DateTime                  @default(now()) @db.Timestamptz(6)
  posted_at                    DateTime?                 @db.Timestamptz(6)
  reference_no                 String?
  notes                        String?
  related_cash_expense_id      String?                   @db.Uuid
  related_work_order_id        String?                   @db.Uuid
  related_inventory_receipt_id String?                   @db.Uuid
  created_by                   String?                   @db.Uuid
  created_at                   DateTime                  @default(now()) @db.Timestamptz(6)
  status                       vendor_transaction_status @default(APPROVED)

  company           companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  created_by_user   users?                   @relation(fields: [created_by], references: [id])
  cash_expense      cash_expenses?           @relation(fields: [related_cash_expense_id], references: [id])
  inventory_receipt inventory_receipts?      @relation(fields: [related_inventory_receipt_id], references: [id])
  work_order        maintenance_work_orders? @relation(fields: [related_work_order_id], references: [id])
  vendor            vendors                  @relation(fields: [vendor_id], references: [id], onDelete: Cascade)

  @@index([company_id], map: "idx_vendor_transactions_company_id")
  @@index([vendor_id], map: "idx_vendor_transactions_vendor_id")
  @@index([transaction_date], map: "idx_vendor_transactions_date")
  @@map("vendor_transactions")
}

model vehicles {
  id                  String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id          String                  @db.Uuid
  created_at          DateTime                @default(now()) @db.Timestamptz(6)
  updated_at          DateTime                @updatedAt @db.Timestamptz(6)
  model               String?
  year                Int?
  current_odometer    Int?
  display_name        String?
  fleet_no            String
  gps_device_id       String?
  plate_no            String
  chassis_no          String?
  engine_no           String?
  ownership_type      vehicle_ownership_type  @default(COMPANY_OWNED)
  disable_reason      vehicle_disable_reason?
  license_expiry_date DateTime?               @db.Timestamptz(6)
  license_issue_date  DateTime?               @db.Timestamptz(6)
  license_no          String?
  status              vehicle_status          @default(AVAILABLE)

  company                  companies                  @relation(fields: [company_id], references: [id], onDelete: Cascade)
  cash_expenses            cash_expenses[]
  maintenance_requests     maintenance_requests[]
  maintenance_work_orders  maintenance_work_orders[]
  installed_part_items     part_items[]               @relation("part_items_installed_vehicle")
  trip_assignments         trip_assignments[]
  work_order_installations work_order_installations[]
  fleet_assignments        fleet_vehicles[]

  @@unique([company_id, fleet_no], map: "uq_vehicles_company_fleet_no")
  @@unique([company_id, plate_no], map: "uq_vehicles_company_plate_no")
  @@unique([company_id, chassis_no], map: "uq_vehicles_company_chassis_no")
  @@unique([company_id, engine_no], map: "uq_vehicles_company_engine_no")
  @@index([company_id], map: "idx_vehicles_company_id")
  @@index([license_expiry_date], map: "idx_vehicles_license_expiry")
  @@index([status], map: "idx_vehicles_status")
  @@map("vehicles")
}

model clients {
  id                    String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id            String   @db.Uuid
  code                  String?
  name                  String
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  primary_contact_name  String?
  primary_contact_phone String?
  primary_contact_email String?
  billing_email         String?
  hq_address            String?
  notes                 String?
  phone                 String?
  tax_no                String?

  company                companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  ar_invoices            ar_invoices[]
  ar_payments            ar_payments[]
  contracts              client_contracts[]
  sites                  sites[]
  trip_revenues          trip_revenues[]
  trips                  trips[]
  contract_pricing_rules contract_pricing_rules[]
  routes                 routes[]

  @@unique([company_id, code], map: "uq_clients_company_code")
  @@index([company_id], map: "idx_clients_company_id")
  @@index([name], map: "idx_clients_name")
  @@map("clients")
}

model client_contracts {
  id                 String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  client_id          String                 @db.Uuid
  contract_no        String?                @unique
  start_date         DateTime               @db.Timestamptz(6)
  end_date           DateTime?              @db.Timestamptz(6)
  signed_at          DateTime?              @db.Timestamptz(6)
  terminated_at      DateTime?              @db.Timestamptz(6)
  termination_reason String?
  document_url       String?
  billing_cycle      contract_billing_cycle @default(MONTHLY)
  contract_value     Decimal?               @db.Decimal(12, 2)
  currency           String?                @default("EGP")
  status             contract_status        @default(ACTIVE)
  notes              String?
  created_at         DateTime               @default(now()) @db.Timestamptz(6)
  updated_at         DateTime               @default(now()) @updatedAt @db.Timestamptz(6)

  client                 clients                  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  ar_invoices            ar_invoices[]
  trip_revenues          trip_revenues[]
  trips                  trips[]
  contract_pricing_rules contract_pricing_rules[]

  @@index([client_id], map: "idx_client_contracts_client_id")
  @@index([status], map: "idx_client_contracts_status")
  @@map("client_contracts")
}

model ar_invoices {
  id               String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String            @db.Uuid
  client_id        String            @db.Uuid
  contract_id      String?           @db.Uuid
  invoice_no       String            @unique
  issue_date       DateTime          @default(now()) @db.Timestamptz(6)
  due_date         DateTime?         @db.Timestamptz(6)
  amount           Decimal           @db.Decimal(12, 2)
  vat_amount       Decimal?          @db.Decimal(12, 2)
  total_amount     Decimal           @db.Decimal(12, 2)
  currency         String?           @default("EGP")
  exchange_rate    Decimal?          @db.Decimal(12, 6)
  status           ar_invoice_status @default(DRAFT)
  created_by       String?           @db.Uuid
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  submitted_by     String?           @db.Uuid
  submitted_at     DateTime?         @db.Timestamptz(6)
  approved_by      String?           @db.Uuid
  approved_at      DateTime?         @db.Timestamptz(6)
  rejection_reason String?
  notes            String?

  company            companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  client             clients                  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  contract           client_contracts?        @relation(fields: [contract_id], references: [id])
  created_by_user    users?                   @relation("ar_invoices_created_by", fields: [created_by], references: [id])
  approved_by_user   users?                   @relation("ar_invoices_approved_by", fields: [approved_by], references: [id])
  invoice_trip_lines ar_invoice_trip_lines[]
  payments           ar_payment_allocations[]
  trip_revenues      trip_revenues[]

  @@index([company_id], map: "idx_ar_invoices_company_id")
  @@index([client_id], map: "idx_ar_invoices_client_id")
  @@index([status], map: "idx_ar_invoices_status")
  @@index([issue_date], map: "idx_ar_invoices_issue_date")
  @@index([due_date], map: "idx_ar_invoices_due_date")
  @@map("ar_invoices")
}

model ar_payments {
  id               String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String            @db.Uuid
  client_id        String            @db.Uuid
  payment_date     DateTime          @default(now()) @db.Timestamptz(6)
  amount           Decimal           @db.Decimal(12, 2)
  currency         String?           @default("EGP")
  exchange_rate    Decimal?          @db.Decimal(12, 6)
  method           ar_payment_method @default(BANK_TRANSFER)
  reference        String?
  notes            String?
  status           ar_payment_status @default(DRAFT)
  created_by       String?           @db.Uuid
  created_at       DateTime          @default(now()) @db.Timestamptz(6)
  submitted_by     String?           @db.Uuid
  submitted_at     DateTime?         @db.Timestamptz(6)
  approved_by      String?           @db.Uuid
  approved_at      DateTime?         @db.Timestamptz(6)
  posted_by        String?           @db.Uuid
  posted_at        DateTime?         @db.Timestamptz(6)
  rejection_reason String?

  company           companies                @relation(fields: [company_id], references: [id], onDelete: Cascade)
  client            clients                  @relation(fields: [client_id], references: [id], onDelete: Cascade)
  created_by_user   users?                   @relation("ar_payments_created_by", fields: [created_by], references: [id])
  submitted_by_user users?                   @relation("ar_payments_submitted_by", fields: [submitted_by], references: [id])
  approved_by_user  users?                   @relation("ar_payments_approved_by", fields: [approved_by], references: [id])
  posted_by_user    users?                   @relation("ar_payments_posted_by", fields: [posted_by], references: [id])
  allocations       ar_payment_allocations[]

  @@index([company_id], map: "idx_ar_payments_company_id")
  @@index([client_id], map: "idx_ar_payments_client_id")
  @@index([status], map: "idx_ar_payments_status")
  @@index([payment_date], map: "idx_ar_payments_payment_date")
  @@map("ar_payments")
}

model ar_payment_allocations {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id       String   @db.Uuid
  payment_id       String   @db.Uuid
  invoice_id       String   @db.Uuid
  amount_allocated Decimal  @db.Decimal(12, 2)
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  company companies   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  payment ar_payments @relation(fields: [payment_id], references: [id], onDelete: Cascade)
  invoice ar_invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade)

  @@unique([payment_id, invoice_id], map: "uq_ar_alloc_payment_invoice")
  @@index([company_id], map: "idx_ar_payment_allocations_company_id")
  @@index([payment_id], map: "idx_ar_alloc_payment_id")
  @@index([invoice_id], map: "idx_ar_alloc_invoice_id")
  @@map("ar_payment_allocations")
}

model ar_invoice_trip_lines {
  id         String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  company_id String  @db.Uuid
  invoice_id String  @db.Uuid
  trip_id    String  @db.Uuid
  amount     Decimal @db.Decimal(12, 2)
  notes      String?

  company companies   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  invoice ar_invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
